{
    "scopeName": "source.basic",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#user_functions" },
        { "include": "#functions" },
        { "include": "#operators" },
        { "include": "#numbers" },
        { "include": "#variables" },
        { "include": "#punctuation" }
    ],

    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.basic",
                    "match": "(?i:(\\bREM\\b|').*)"
                },
                {
                    "name": "comment.block.basic",
                    "begin": "/'",
                    "end": "'/"
                }
            ]
        },

        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.basic",
                    "match": "(?i:\\b(AFTER|AUTO|BEEP|BLOAD|BSAVE|CALL|CAT|CHAIN MERGE|CHAIN|CLEAR|CLOSE|CLS|COLOR|COMMON|CONT|COPY|DATA|DEF FN|DEFDBL|DEFINT|DEFSNG|DEFSTR|DELETE|DIM|DRAW|EDIT|ELSE|END|ERASE|ERROR|FIELD|FILES|FOR|GET|GOSUB|GOTO|IF|INPUT|KEY|KILL|LET|LINE INPUT|LIST|LOAD|LOCATE|LPRINT|LSET|MERGE|MID\\$|NAME|NEW|NEXT|ON|OPEN|OPTION BASE|OUT|PAINT|POKE|PRINT|PUT|RANDOMIZE|READ|RESTORE|RESUME|RETURN|RSET|RUN|SAVE|SCREEN|SET|SHELL|SLEEP|SOUND|STEP|STOP|SWAP|SYSTEM|THEN|TO|USING|VIEW|WAIT|WEND|WHILE|WIDTH|WINDOW|WRITE)\\b)"
                }
            ]
        },

        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.basic",
                    "match": "(?i:\\b(ABS|ASC|ATN|BIN\\$|CDBL|CHR\\$|CINT|COS|CSNG|DATE\\$|EOF|ERL|ERR|EXP|FIX|FRE|HEX\\$|INKEY\\$|INSTR|INT|LEFT\\$|LEN|LOG|MID\\$|OCT\\$|PEEK|POS|RIGHT\\$|RND|ROUND|SGN|SIN|SPACE\\$|SPC|SQR|STR\\$|STRING\\$|TAB|TAN|TIME\\$|VAL|XPOS|YPOS)\\b)"
                }
            ]
        },

        "user_functions": {
            "patterns": [
                {
                    "name": "entity.name.function.user.basic",
                    "match": "(?i:(?<![A-Za-z0-9])\\*\\s*[A-Za-z][A-Za-z0-9]*)"
                }
            ]
        },

        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.basic",
                    "match": "(?i:\\b(AND|OR|NOT|XOR|EQV|IMP|MOD)\\b)"
                },
                {
                    "name": "keyword.operator.arithmetic.basic",
                    "match": "[\\+\\-\\*/=<>\\^]+"
                }
            ]
        },

        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.basic",
                    "match": "-?\\b((([0-9]+\\.?[0-9]*)|(\\.[0-9]+))((e|E)(\\+|-)?[0-9]+)?)(L|l|UL|ul|u|U|F|f)?\\b"
                },
                {
                    "name": "constant.numeric.hex.basic",
                    "match": "\\$[A-Fa-f0-9]+"
                }
            ]
        },

        "variables": {
            "patterns": [
                {
                    "name": "variable.name.basic",
                    "match": "\\b[A-Za-z][A-Za-z0-9]*\\$?"
                }
            ]
        },

        "strings": {
            "name": "string.quoted.double.basic",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.basic",
                    "match": "\\\\."
                }
            ]
        },

        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.section.group.begin.basic",
                    "match": "\\("
                },
                {
                    "name": "punctuation.section.group.end.basic",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.separator.basic",
                    "match": "[,:;]"
                }
            ]
        }
    }
}